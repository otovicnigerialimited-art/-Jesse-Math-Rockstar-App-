rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /usernames/{username} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    match /matchmaking_queue/{docId} {
      allow read, write: if true;
    }

    match /arena_games/{gameId} {
      allow read, write: if true;
    }

    match /developer_guestbook/{docId} {
      allow read, write: if true;
    }

    match /schools/{docId} {
      allow read, write: if true;
    }

    match /school_admins/{docId} {
      allow read, write: if true;
    }

    match /teachers/{docId} {
      allow read, write: if true;
    }

    match /students/{docId} {
      allow read, write: if true;
    }

    match /school_students/{docId} {
      allow read, write: if true;
    }

    match /shop_items/{docId} {
      allow read, write: if true;
    }

    match /student_activity_logs/{docId} {
      allow read, write: if true;
    }
  }
}
