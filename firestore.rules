rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Since the Jesse Rock Math Arena application uses a custom, client-side identity 
    // and session management scheme (stored in localStorage) and does not utilize 
    // standard Firebase Authentication (request.auth is null), we allow read and write 
    // access for all required collections to ensure gameplay, registration, and leaderboard 
    // synchronization function flawlessly.

    match /usernames/{username} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    match /school_students/{studentId} {
      allow read, write: if true;
    }

    match /teachers/{teacherId} {
      allow read, write: if true;
    }

    match /schools/{docId} {
      allow read, write: if true;
    }

    match /matchmaking_queue/{docId} {
      allow read, write: if true;
    }

    match /arena_games/{gameId} {
      allow read, write: if true;
    }

    match /system_state/{docId} {
      allow read, write: if true;
    }

    match /developer_guestbook/{docId} {
      allow read, write: if true;
    }

    match /shop_items/{docId} {
      allow read, write: if true;
    }

    // Default fallback
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
