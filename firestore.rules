rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Since this application utilizes a custom client-side registry and database-backed identity
    // (with browser cookies, device IDs, and a custom /usernames collection with client-side passwords),
    // we allow public reads and writes on all required collections to prevent permission blockages.

    match /usernames/{username} {
      allow read, write: if true;
    }

    match /leaderboard/{document} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    match /school_students/{studentId} {
      allow read, write: if true;
    }

    match /teachers/{teacherId} {
      allow read, write: if true;
    }

    match /schools/{schoolId} {
      allow read, write: if true;
    }

    match /arena_games/{gameId} {
      allow read, write: if true;
    }

    match /matchmaking_queue/{docId} {
      allow read, write: if true;
    }

    match /developer_guestbook/{docId} {
      allow read, write: if true;
    }

    match /shop_items/{docId} {
      allow read, write: if true;
    }

    match /system_state/{docId} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
