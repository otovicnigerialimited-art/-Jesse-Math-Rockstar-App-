rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: Verify if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Check if user is owner of document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Default Deny: Secure by default
    match /{document=**} {
      allow read, write: if false;
    }

    match /usernames/{username} {
      allow read: if isSignedIn();
      allow write: if false; // Disallow tampering
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /schools/{docId} {
      allow read: if isSignedIn();
      allow write: if false; // Should be admin-managed
    }

    // Generic collections access restricted to authenticated users
    match /matchmaking_queue/{docId} {
      allow read, write: if isSignedIn();
    }

    match /arena_games/{gameId} {
      allow read, write: if isSignedIn();
    }
  }
}
